# Скопируйте в .env: cp .env.example .env
# Не коммитьте .env с реальными секретами.

# Пароль Redis (обязателен для docker compose up). Сгенерировать: openssl rand -hex 32
# Избегайте символа $ в пароле — в .env он интерпретируется Docker Compose.
REDIS_PASSWORD=change_me_set_strong_secret_here

# URL robot-gateway внутри Docker/k8s (для навыков salute и alice)
ROBOT_GATEWAY_URL=robot-gateway:50051
